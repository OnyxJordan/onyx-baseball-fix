"""
onyx_build_career_dbs.py — Onyx Baseball career DB builder
Reads FanGraphs CSV exports → builds career_db.json + pitcher_db.json

Input files (place in same folder or pass --data-dir):
  Hitters:
    202426 Fangraphs Hitters.csv   — overall 2024-26 stats (p3/i3/e3/b3/h3/c)
    202426 Statcast.csv            — 2024-26 Statcast (EV90/Barrel%/HardHit%)
    202426 Hitters Home.csv        — 2024-26 home splits (ch)
    202426 Hitters Away.csv        — 2024-26 away splits (ca)
    2026 Hitters Home.csv          — 2026 home splits (i6/e6/b6/h6)
    2026 Hitters Away.csv          — 2026 away splits
    [2026 Fangraphs Hitters.csv]   — 2026 overall (p6) — optional, derived from splits if absent

  Pitchers:
    202426 Pitching Overall.csv    — 2024-26 overall (xf3/e3/h3)
    202426 Pitching Statcast.csv   — 2024-26 Statcast (EV/Barrel%)
    2026 Pitching.csv              — 2026 overall (xf6/e6/h6)
    2026 Pitching Home.csv         — 2026 home (pfh)
    2026 Pitching Away.csv         — 2026 away (pfa)

Output:
    career_db.json.rebuilt
    pitcher_db.json.rebuilt
    build_report.txt
"""

import csv, json, os, sys, math, unicodedata, re
from pathlib import Path
from collections import defaultdict

# ── CONFIG ────────────────────────────────────────────────────────────────────
DATA_DIR = Path(".")          # override with --data-dir <path>
EXISTING_CAREER  = Path("career_db.json")
EXISTING_PITCHER = Path("pitcher_db.json")

# Minimum PA/IP thresholds
MIN_PA_3  = 50    # for _3 fields
MIN_PA_6  = 10    # for _6 fields
MIN_IP_3  = 10
MIN_IP_6  = 1

# Bayesian pf floor/cap
PF_MIN, PF_MAX = 0.60, 1.80
LEAGUE_XFIP    = 4.00   # reference xFIP for pf=1.0

# ── NAME NORMALISATION ────────────────────────────────────────────────────────
def norm(s):
    s = unicodedata.normalize("NFKD", str(s)).encode("ascii", "ignore").decode()
    s = s.lower().strip()
    s = re.sub(r"[.'`\-]", " ", s)
    s = re.sub(r"\b(jr|sr|ii|iii|iv)\b", "", s)
    return re.sub(r"\s+", " ", s).strip()

# ── CSV READER ────────────────────────────────────────────────────────────────
def read_csv(fname):
    path = DATA_DIR / fname
    if not path.exists():
        print(f"  MISSING: {fname}")
        return []
    rows = []
    with open(path, newline="", encoding="utf-8-sig") as f:
        reader = csv.DictReader(f)
        for row in reader:
            rows.append({k.strip(): v.strip() for k, v in row.items()})
    print(f"  Loaded {len(rows):4d} rows  ← {fname}")
    return rows

def flt(v, default=0.0):
    try:
        s = str(v).replace("%", "").replace(",", "").strip()
        return float(s) if s not in ("", "-", "N/A", "null") else default
    except:
        return default

def detect_pct(val, col_name=""):
    """Auto-detect % vs decimal for Barrel%/HardHit% columns."""
    v = flt(val)
    # FanGraphs exports Barrel% as e.g. 8.3 (percent) not 0.083
    # but some exports may be decimal — check magnitude
    if v > 1.0:
        return v / 100.0
    return v

# ── HITTER DB ─────────────────────────────────────────────────────────────────
def build_hitter_db():
    print("\n── HITTERS ──")

    # Load existing DB for merge
    existing = {}
    if EXISTING_CAREER.exists():
        existing = json.loads(EXISTING_CAREER.read_text())
        print(f"  Existing career_db: {len(existing)} players")

    # ── 2024-26 overall ───────────────────────────────────────────────────────
    overall3 = {}
    for row in read_csv("202426 Fangraphs Hitters.csv"):
        key = norm(row.get("Name", ""))
        pa  = int(flt(row.get("PA", 0)))
        hr  = int(flt(row.get("HR", 0)))
        if pa < MIN_PA_3 or not key:
            continue
        overall3[key] = {
            "p3":  pa,
            "c":   round(hr / pa, 5) if pa > 0 else 0,
            "i3":  flt(row.get("ISO", 0)),
        }

    # ── 2024-26 Statcast ──────────────────────────────────────────────────────
    stat3 = {}
    for row in read_csv("202426 Statcast.csv"):
        key = norm(row.get("Name", ""))
        pa  = int(flt(row.get("PA", 0)))
        if pa < MIN_PA_3 or not key:
            continue
        b_raw = flt(row.get("Barrel%", 0))
        h_raw = flt(row.get("HardHit%", 0))
        stat3[key] = {
            "e3": round(flt(row.get("EV90", 0)), 1),
            "b3": round(detect_pct(b_raw), 4),
            "h3": round(detect_pct(h_raw), 4),
        }

    # ── 2024-26 home/away splits ──────────────────────────────────────────────
    home3, away3 = {}, {}
    for row in read_csv("202426 Hitters Home.csv"):
        key = norm(row.get("Name", ""))
        pa  = int(flt(row.get("PA", 0)))
        hr  = int(flt(row.get("HR", 0)))
        if pa >= MIN_PA_3 and key:
            home3[key] = {"pa": pa, "hr": hr}
    for row in read_csv("202426 Hitters Away.csv"):
        key = norm(row.get("Name", ""))
        pa  = int(flt(row.get("PA", 0)))
        hr  = int(flt(row.get("HR", 0)))
        if pa >= MIN_PA_3 and key:
            away3[key] = {"pa": pa, "hr": hr}

    # ── 2026 home/away splits ─────────────────────────────────────────────────
    home6, away6 = {}, {}
    for row in read_csv("2026 Hitters Home.csv"):
        key = norm(row.get("Name", ""))
        pa  = int(flt(row.get("PA", 0)))
        hr  = int(flt(row.get("HR", 0)))
        iso = flt(row.get("ISO", 0))
        if pa >= MIN_PA_6 and key:
            home6[key] = {"pa": pa, "hr": hr, "iso": iso}
    for row in read_csv("2026 Hitters Away.csv"):
        key = norm(row.get("Name", ""))
        pa  = int(flt(row.get("PA", 0)))
        hr  = int(flt(row.get("HR", 0)))
        iso = flt(row.get("ISO", 0))
        if pa >= MIN_PA_6 and key:
            away6[key] = {"pa": pa, "hr": hr, "iso": iso}

    # ── Merge into DB ─────────────────────────────────────────────────────────
    all_keys = set(overall3) | set(stat3) | set(home3) | set(away3) | set(home6) | set(away6) | set(existing)
    db = {}
    for key in all_keys:
        rec = dict(existing.get(key, {}))  # start from existing

        o3 = overall3.get(key, {})
        s3 = stat3.get(key, {})
        h3 = home3.get(key, {})
        a3 = away3.get(key, {})
        h6 = home6.get(key, {})
        a6 = away6.get(key, {})

        # _3 fields
        if o3:
            rec["p3"] = o3["p3"]
            rec["c"]  = o3["c"]
            rec["i3"] = o3["i3"]
        if s3:
            rec["e3"] = s3["e3"]
            rec["b3"] = s3["b3"]
            rec["h3"] = s3["h3"]

        # home/away HR/PA splits (ch/ca) from _3 window
        if h3 and h3["pa"] > 0:
            rec["ch"] = round(h3["hr"] / h3["pa"], 5)
        if a3 and a3["pa"] > 0:
            rec["ca"] = round(a3["hr"] / a3["pa"], 5)

        # _6 fields (2026 season-to-date)
        p6_home = h6.get("pa", 0)
        p6_away = a6.get("pa", 0)
        p6_total = p6_home + p6_away
        hr6_total = h6.get("hr", 0) + a6.get("hr", 0)

        rec["p6"] = p6_total
        if p6_total > 0:
            rec["i6"] = round((h6.get("iso", 0) * p6_home + a6.get("iso", 0) * p6_away) / p6_total, 4) if p6_total > 0 else 0
        else:
            rec["i6"] = rec.get("i6", 0)

        if h6:
            rec["h6"] = round(h6["hr"] / h6["pa"], 5) if h6["pa"] > 0 else 0
        if a6:
            rec["a6"] = round(a6["hr"] / a6["pa"], 5) if a6["pa"] > 0 else 0

        # e6/b6 — not in split files, inherit from _3 as best proxy
        rec["e6"] = rec.get("e3", 95)
        rec["b6"] = rec.get("b3", 0.08)

        db[key] = rec

    print(f"  → career_db: {len(db)} players")
    return db

# ── PITCHER DB ────────────────────────────────────────────────────────────────
def build_pitcher_db():
    print("\n── PITCHERS ──")

    existing = {}
    if EXISTING_PITCHER.exists():
        existing = json.loads(EXISTING_PITCHER.read_text())
        print(f"  Existing pitcher_db: {len(existing)} pitchers")

    # ── 2024-26 overall ───────────────────────────────────────────────────────
    overall3 = {}
    for row in read_csv("202426 Pitching Overall.csv"):
        key = norm(row.get("Name", ""))
        ip  = flt(row.get("IP", 0))
        if ip < MIN_IP_3 or not key:
            continue
        xfip = flt(row.get("xFIP", LEAGUE_XFIP))
        era  = flt(row.get("ERA", 4.5))
        hr9  = flt(row.get("HR/9", 1.0))
        overall3[key] = {
            "xf3": round(xfip, 3),
            "e3":  round(era, 3),
            "h3":  round(hr9, 3),
            "ip3": ip,
        }

    # ── 2024-26 Statcast (used to calibrate pf) ───────────────────────────────
    # We don't use statcast directly for pitcher_db fields but keep for reference
    # pf = xFIP / LEAGUE_XFIP (self-calibrating)

    # ── 2026 overall ──────────────────────────────────────────────────────────
    overall6 = {}
    for row in read_csv("2026 Pitching.csv"):
        key = norm(row.get("Name", ""))
        ip  = flt(row.get("IP", 0))
        if ip < MIN_IP_6 or not key:
            continue
        overall6[key] = {
            "xf6": round(flt(row.get("xFIP", 0)), 3),
            "e6":  round(flt(row.get("ERA",  0)), 3),
            "h6":  round(flt(row.get("HR/9", 0)), 3),
            "ip6": ip,
        }

    # ── 2026 home/away splits ─────────────────────────────────────────────────
    home6, away6 = {}, {}
    for row in read_csv("2026 Pitching Home.csv"):
        key = norm(row.get("Name", ""))
        ip  = flt(row.get("IP", 0))
        if ip < MIN_IP_6 and not key:
            continue
        if key:
            home6[key] = {
                "xfip": flt(row.get("xFIP", LEAGUE_XFIP)),
                "ip":   ip,
            }
    for row in read_csv("2026 Pitching Away.csv"):
        key = norm(row.get("Name", ""))
        ip  = flt(row.get("IP", 0))
        if key:
            away6[key] = {
                "xfip": flt(row.get("xFIP", LEAGUE_XFIP)),
                "ip":   ip,
            }

    # ── Self-calibrate pf convention ──────────────────────────────────────────
    # pf = xFIP_3 / LEAGUE_XFIP  (same formula as existing DB)
    # Verify against existing: sample a few known pitchers
    calibration_log = []
    if existing:
        sample = list(existing.items())[:5]
        for k, v in sample:
            o = overall3.get(k, {})
            if o:
                calc_pf = round(o["xf3"] / LEAGUE_XFIP, 3)
                stored  = v.get("pf", 0)
                calibration_log.append(f"  {k}: stored_pf={stored} calc_pf={calc_pf} xf3={o['xf3']}")

    # ── Merge ─────────────────────────────────────────────────────────────────
    all_keys = set(overall3) | set(overall6) | set(home6) | set(away6) | set(existing)
    db = {}
    for key in all_keys:
        rec = dict(existing.get(key, {}))

        o3 = overall3.get(key, {})
        o6 = overall6.get(key, {})
        h6 = home6.get(key, {})
        a6 = away6.get(key, {})

        # _3 fields
        if o3:
            rec["xf3"] = o3["xf3"]
            rec["e3"]  = o3["e3"]
            rec["h3"]  = o3["h3"]
            rec["pf"]  = round(max(PF_MIN, min(PF_MAX, o3["xf3"] / LEAGUE_XFIP)), 3)

        # _6 fields
        if o6:
            rec["xf6"] = o6["xf6"]
            rec["e6"]  = o6["e6"]
            rec["h6"]  = o6["h6"]
        else:
            # pitcher had no 2026 IP — zero out current-season fields
            rec["xf6"] = 0
            rec["e6"]  = 0
            rec["h6"]  = 0

        # pfh / pfa from 2026 home/away xFIP
        if h6 and h6["ip"] >= MIN_IP_6:
            rec["pfh"] = round(max(PF_MIN, min(PF_MAX, h6["xfip"] / LEAGUE_XFIP)), 3)
        elif not rec.get("pfh"):
            rec["pfh"] = rec.get("pf", 1.0)

        if a6 and a6["ip"] >= MIN_IP_6:
            rec["pfa"] = round(max(PF_MIN, min(PF_MAX, a6["xfip"] / LEAGUE_XFIP)), 3)
        elif not rec.get("pfa"):
            rec["pfa"] = rec.get("pf", 1.0)

        db[key] = rec

    print(f"  → pitcher_db: {len(db)} pitchers")
    return db, calibration_log

# ── VERIFICATION REPORT ───────────────────────────────────────────────────────
def verify(hitter_db, pitcher_db, cal_log):
    lines = ["=" * 60, "ONYX CAREER DB BUILD REPORT", "=" * 60]

    # Hitter checks
    lines.append("\n── HITTER CHECKS ──")
    checks = [
        ("aaron judge",     {"p3": (1400, 1800), "p6": (100, 350), "c": (0.05, 0.10)}),
        ("jurickson profar",{"p6": (0, 20)}),   # suspended — p6 should be ~0
        ("shohei ohtani",   {"p3": (500, 1000), "c": (0.05, 0.12)}),
        ("mike trout",      {"p3": (100, 800),  "c": (0.04, 0.12)}),
    ]
    for name, expectations in checks:
        key = norm(name)
        rec = hitter_db.get(key)
        if not rec:
            lines.append(f"  MISSING: {name}")
            continue
        issues = []
        for field, (lo, hi) in expectations.items():
            val = rec.get(field, None)
            if val is None:
                issues.append(f"{field}=MISSING")
            elif not (lo <= val <= hi):
                issues.append(f"{field}={val} (expected {lo}-{hi})")
        status = "✓" if not issues else "✗ " + ", ".join(issues)
        lines.append(f"  {name}: p3={rec.get('p3',0)} p6={rec.get('p6',0)} c={rec.get('c',0):.4f} ch={rec.get('ch',0):.4f} ca={rec.get('ca',0):.4f}  {status}")

    # Pitcher checks
    lines.append("\n── PITCHER CHECKS ──")
    pit_checks = [
        ("tarik skubal",   {"pf": (0.55, 0.80), "xf3": (2.0, 3.5)}),
        ("paul skenes",    {"pf": (0.55, 0.85), "xf3": (2.0, 3.5)}),
        ("gerrit cole",    {"pf": (0.80, 1.20)}),
    ]
    for name, expectations in pit_checks:
        key = norm(name)
        rec = pitcher_db.get(key)
        if not rec:
            lines.append(f"  MISSING: {name}")
            continue
        issues = []
        for field, (lo, hi) in expectations.items():
            val = rec.get(field, None)
            if val is None:
                issues.append(f"{field}=MISSING")
            elif not (lo <= val <= hi):
                issues.append(f"{field}={val} (expected {lo}-{hi})")
        status = "✓" if not issues else "✗ " + ", ".join(issues)
        lines.append(f"  {name}: pf={rec.get('pf',0)} xf3={rec.get('xf3',0)} xf6={rec.get('xf6',0)} pfh={rec.get('pfh',0)} pfa={rec.get('pfa',0)}  {status}")

    # pf calibration
    lines.append("\n── pf CALIBRATION (sample) ──")
    lines += cal_log if cal_log else ["  (no existing DB to compare)"]

    # Coverage
    lines.append(f"\n── COVERAGE ──")
    lines.append(f"  Hitters: {len(hitter_db)} total | with p6>0: {sum(1 for v in hitter_db.values() if v.get('p6',0)>0)}")
    lines.append(f"  Pitchers: {len(pitcher_db)} total | with xf6>0: {sum(1 for v in pitcher_db.values() if v.get('xf6',0)>0)}")
    lines.append(f"  Hitters with ch+ca: {sum(1 for v in hitter_db.values() if v.get('ch') and v.get('ca'))}")

    return "\n".join(lines)

# ── MAIN ──────────────────────────────────────────────────────────────────────
def main():
    global DATA_DIR

    # Parse --data-dir arg
    args = sys.argv[1:]
    if "--data-dir" in args:
        idx = args.index("--data-dir")
        DATA_DIR = Path(args[idx + 1])

    print(f"onyx_build_career_dbs.py  |  data dir: {DATA_DIR.resolve()}\n")

    hitter_db = build_hitter_db()
    pitcher_db, cal_log = build_pitcher_db()

    report = verify(hitter_db, pitcher_db, cal_log)
    print("\n" + report)

    # Write outputs
    out_h = DATA_DIR / "career_db.json.rebuilt"
    out_p = DATA_DIR / "pitcher_db.json.rebuilt"
    out_r = DATA_DIR / "build_report.txt"

    out_h.write_text(json.dumps(hitter_db, indent=2))
    out_p.write_text(json.dumps(pitcher_db, indent=2))
    out_r.write_text(report)

    print(f"\n✅ Wrote:")
    print(f"   {out_h}  ({len(hitter_db)} players)")
    print(f"   {out_p}  ({len(pitcher_db)} pitchers)")
    print(f"   {out_r}")
    print("\nIf report looks good → rename .rebuilt files over originals and commit.")

if __name__ == "__main__":
    main()
